{
  "name": "sarah-chatbot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "widget",
    "dashboard"
  ],
  "scripts": {
    "dev": "docker compose up -d postgres redis && npm run dev:server",
    "dev:server": "npm -w server run dev",
    "dev:widget": "npm -w widget run dev",
    "dev:dashboard": "npm -w dashboard run dev",
    "build": "npm -w widget run build && npm -w dashboard run build",
    "start": "npm -w server start",
    "test": "npm -w server test"
  },
  "dependencies": {
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "vitest": "^4.0.18",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2"
  }
}
