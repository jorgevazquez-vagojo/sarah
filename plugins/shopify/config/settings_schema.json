[
  {
    "name": "RDGBot",
    "settings": [
      {
        "type": "checkbox",
        "id": "rdgbot_enabled",
        "label": "Enable Chatbot Widget",
        "default": false
      },
      {
        "type": "text",
        "id": "rdgbot_server_url",
        "label": "Chatbot Server URL",
        "default": "https://chatbot.redegal.com",
        "info": "URL of your RDGBot server"
      },
      {
        "type": "text",
        "id": "rdgbot_api_key",
        "label": "API Key",
        "info": "Your widget API key"
      },
      {
        "type": "color",
        "id": "rdgbot_primary_color",
        "label": "Primary Color",
        "default": "#007fff"
      },
      {
        "type": "image_picker",
        "id": "rdgbot_logo",
        "label": "Chat Logo"
      },
      {
        "type": "select",
        "id": "rdgbot_language",
        "label": "Default Language",
        "default": "auto",
        "options": [
          { "value": "auto", "label": "Auto-detect" },
          { "value": "es", "label": "Español" },
          { "value": "en", "label": "English" },
          { "value": "pt", "label": "Português" },
          { "value": "gl", "label": "Galego" }
        ]
      },
      {
        "type": "select",
        "id": "rdgbot_position",
        "label": "Widget Position",
        "default": "bottom-right",
        "options": [
          { "value": "bottom-right", "label": "Bottom Right" },
          { "value": "bottom-left", "label": "Bottom Left" }
        ]
      }
    ]
  }
]
