{% comment %}
  Redegal Chatbot - Shopify Theme Snippet

  Usage: Add to theme.liquid before </body>:
    {% render 'redegal-chatbot' %}

  Configure in Shopify Admin > Theme > Customize > Theme settings
{% endcomment %}

{% if settings.redegal_chatbot_enabled %}
<script>
  window.RedegalChatbot = {
    baseUrl: '{{ settings.redegal_chatbot_server_url | append: "/widget" }}',
    apiUrl: '{{ settings.redegal_chatbot_server_url | replace: "https://", "wss://" | replace: "http://", "ws://" | append: "/ws/chat" }}',
    configUrl: '{{ settings.redegal_chatbot_server_url | append: "/api/config/widget" }}',
    language: '{{ settings.redegal_chatbot_language | default: "auto" }}',
    primaryColor: '{{ settings.redegal_chatbot_primary_color | default: "#E30613" }}',
    theme: {
      branding: {
        companyName: '{{ shop.name }}',
        logoUrl: '{{ settings.redegal_chatbot_logo | image_url: width: 200 }}'
      },
      layout: {
        position: '{{ settings.redegal_chatbot_position | default: "bottom-right" }}'
      }
    }
  };
</script>
<script src="{{ settings.redegal_chatbot_server_url | append: '/widget/loader.js' }}" async></script>
{% endif %}
