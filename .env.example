# ─── Database ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rdgbot
POSTGRES_USER=redegal
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ───
REDIS_HOST=redis
REDIS_PASSWORD=change_me_in_production

# ─── AI Providers ───
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── Server ───
PORT=9456
NODE_ENV=development
JWT_SECRET=change_me_in_production
WIDGET_API_KEY=change_me_in_production

# ─── PBX / Click2Call (Vozelia Cloud PBX via SIP) ───
SIP_DOMAIN=cloudpbx1584.vozelia.com
SIP_EXTENSION=108
SIP_PASSWORD=
CLICK2CALL_CALLERID_NAME=Lead Web
CLICK2CALL_EXTENSIONS=107,158,105

# ─── AMI (not available on Vozelia cloud — Click2Call uses SIP) ───
ASTERISK_AMI_HOST=
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=
ASTERISK_AMI_PASSWORD=

# ─── CORS ───
ALLOWED_ORIGINS=https://redegal.com,https://www.redegal.com,http://localhost:9456

# ─── Business Hours (Europe/Madrid) ───
TIMEZONE=Europe/Madrid
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=19

# ─── Email / SMTP ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=chatbot@redegal.com
NOTIFICATION_EMAIL=

# ─── Janus WebRTC Gateway ───
JANUS_URL=http://janus:8088/janus
JANUS_WS_URL=ws://janus:8188
JANUS_ADMIN_URL=http://janus:7088/admin
JANUS_ADMIN_SECRET=change_me_in_production
JANUS_PUBLIC_WS=ws://localhost:8188
SERVER_PUBLIC_IP=

# ─── Redegal Branding ───
PRIMARY_COLOR=#007fff
