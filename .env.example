# ─── Sarah Server Configuration ───
#
# IMPORTANT: In production, use a secrets manager (AWS Secrets Manager, HashiCorp Vault,
# Doppler, etc.) instead of a .env file. Never commit real credentials to version control.
# This file contains placeholder values only.

# ─── Database ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rdgbot
POSTGRES_USER=redegal
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ─── Redis ───
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# ─── AI Providers ───
AI_PROVIDER=gemini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ─── Server ───
PORT=9456
NODE_ENV=development
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
WIDGET_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ─── Encryption (for CRM credentials at rest) ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, a key will be derived from JWT_SECRET via PBKDF2
ENCRYPTION_KEY=

# ─── PBX / Click2Call (Vozelia Cloud PBX via SIP) ───
SIP_DOMAIN=your-pbx-domain.example.com
SIP_EXTENSION=100
SIP_PASSWORD=
CLICK2CALL_CALLERID_NAME=Lead Web
CLICK2CALL_EXTENSIONS=101,102,103

# ─── AMI (not available on Vozelia cloud — Click2Call uses SIP) ───
ASTERISK_AMI_HOST=
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=
ASTERISK_AMI_PASSWORD=

# ─── CORS ───
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Business Hours (Europe/Madrid) ───
TIMEZONE=Europe/Madrid
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=19

# ─── Email / SMTP ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=chatbot@yourdomain.com
NOTIFICATION_EMAIL=

# ─── Janus WebRTC Gateway ───
JANUS_URL=http://janus:8088/janus
JANUS_WS_URL=ws://janus:8188
JANUS_ADMIN_URL=http://janus:7088/admin
JANUS_ADMIN_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET
JANUS_PUBLIC_WS=ws://localhost:8188
SERVER_PUBLIC_IP=

# ─── Redegal Branding ───
PRIMARY_COLOR=#007fff
