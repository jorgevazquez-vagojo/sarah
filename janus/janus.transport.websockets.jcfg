# Janus WebSocket Transport
# Widget connects here for WebRTC signaling

general: {
  json = "indented"
  ws = true
  ws_port = 8188
  # ws_ip not set — binds to all interfaces (0.0.0.0 is not a valid interface IP in Janus)
  # WSS disabled — handled by nginx reverse proxy in production
  wss = false
  ws_logging = "err,warn"
}

admin: {
  admin_ws = false
}
